# Environment Variables Template
# Copy this file to .env and fill in your values

# Database Configuration
DB_SERVER=synw-aquas.sql.azuresynapse.net
DB_DATABASE=aquas
AUTH_MODE=ActiveDirectoryIntegrated

# Base Paths
# Set to the root directory of the project
BASE_DIR=C:/Users/YourUsername/Desktop/GIT

# Reference data file
UP_RS_FILE=C:/Users/YourUsername/Desktop/PREDAP/UP per RS.xlsx

# Logging
LOG_LEVEL=INFO
